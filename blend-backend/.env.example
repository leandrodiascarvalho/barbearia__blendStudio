# ─── Ambiente ──────────────────────────────────────────────
# NODE_ENV=development | production | test
NODE_ENV=development
PORT=3000

# ─── Origem Permitida (CORS) ──────────────────────────────
# Em produção: URL do domínio real (ex: https://blendstudio.com.br)
# Em desenvolvimento: http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# ─── Cal.com ──────────────────────────────────────────────
# 1. Crie uma conta gratuita em: https://cal.com/signup
# 2. Vá em: Settings → Security → API Keys
# 3. Crie uma nova API key e cole abaixo
CALCOM_API_KEY=cal_live_baf3af3e27e3a37c0b2e624d33f2cc23

# ─── Segurança ────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=gere_uma_chave_segura_com_minimo_32_caracteres
