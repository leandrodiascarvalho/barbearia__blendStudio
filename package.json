{
  "name": "blend-studio-frontend",
  "version": "2.0.0",
  "description": "Frontend da Blend Studio Barbearia",
  "scripts": {
    "dev": "npm run scss:watch",
    "build": "npm run scss:build",
    "scss:watch": "sass blend-frontend/scss/main.scss blend-frontend/css/main.css --watch --style=expanded --source-map",
    "scss:build": "sass blend-frontend/scss/main.scss blend-frontend/css/main.css --style=compressed --no-source-map",
    "copy:bootstrap": "node scripts/copy-bootstrap.js",
    "postinstall": "npm run copy:bootstrap"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3"
  },
  "devDependencies": {
    "sass": "^1.77.6"
  }
}